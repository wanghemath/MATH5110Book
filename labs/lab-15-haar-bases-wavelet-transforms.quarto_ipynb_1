        "\n",
        "## Part 2: Compression by thresholding"
      ],
      "id": "920fa463"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "u = np.array([2.4, 2.2, 2.15, 2.05, 6.8, 2.8, -1.1, -1.3])\n",
        "c = haar_transform(u)\n",
        "threshold = 0.2\n",
        "chat = c.copy()\n",
        "chat[np.abs(chat) <= threshold] = 0\n",
        "uhat = inverse_haar_transform(chat)\n",
        "print(\"coefficients:\", np.round(c, 3))\n",
        "print(\"compressed coefficients:\", np.round(chat, 3))\n",
        "print(\"reconstruction:\", np.round(uhat, 3))\n",
        "print(\"error norm:\", np.linalg.norm(u-uhat))"
      ],
