        "### Example 13.40: Cholesky factorization"
      ],
      "id": "06b79027"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "C = np.array([[4, 2, 0],\n",
        "              [2, 5, 1],\n",
        "              [0, 1, 3]], dtype=float)\n",
        "\n",
        "L = np.linalg.cholesky(C)\n",
        "print(\"L =\")\n",
        "print(np.round(L, 6))\n",
        "print(\"Reconstruction error:\", np.linalg.norm(C - L @ L.T))"
      ],
