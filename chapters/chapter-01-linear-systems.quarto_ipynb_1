        "---\n",
        "title: \"Chapter 1. The First Language: Systems, Sets, and Structure\"\n",
        "subtitle: \"From ordinary equations to the grammar of linear algebra\"\n",
        "format:\n",
        "  html:\n",
        "    toc: true\n",
        "    toc-depth: 3\n",
        "    number-sections: true\n",
        "    code-fold: show\n",
        "    code-tools: true\n",
