        "B = np.array([[1,1],\n",
        "              [0,1]])\n",
        "\n",
        "print(\"AB =\")\n",
        "print(A @ B)\n",
        "\n",
        "print(\"BA =\")\n",
        "print(B @ A)\n",
        "\n",
        "print(\"A^3 =\")\n",
        "print(np.linalg.matrix_power(A, 3))"
      ],
