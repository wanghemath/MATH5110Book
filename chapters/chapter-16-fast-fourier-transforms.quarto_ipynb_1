        "---\n",
        "title: \"Chapter 16: Fast Fourier Transforms\"\n",
        "subtitle: \"From Time Samples to Frequency Coordinates\"\n",
        "author: \"He Wang\"\n",
        "format:\n",
        "  html:\n",
        "    toc: true\n",
        "    number-sections: true\n",
