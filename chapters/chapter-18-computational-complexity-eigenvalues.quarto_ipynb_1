        "---\n",
        "title: \"Chapter 18: Computational Complexity and Computation of Eigenvalues\"\n",
        "subtitle: \"When the formula is correct, but the computation is too large\"\n",
        "author: \"He Wang\"\n",
        "format:\n",
        "  html:\n",
        "    toc: true\n",
