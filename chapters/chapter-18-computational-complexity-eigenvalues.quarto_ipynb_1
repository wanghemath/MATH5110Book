        "for n in sizes:\n",
        "    data.append({\n",
        "        \"n\": n,\n",
        "        \"n\": n,\n",
        "        \"n log2 n\": n*np.log2(n),\n",
        "        \"n^2\": n**2,\n",
        "        \"n^3\": n**3,\n",
